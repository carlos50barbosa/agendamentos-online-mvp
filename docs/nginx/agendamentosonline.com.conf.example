server {
  listen 80;
  server_name agenda0.com.br www.agenda0.com.br;

  root /var/www/agenda0.com.br;
  index index.html;

  location = /api {
    return 301 /api/;
  }

  # Prefixo legado: links antigos (e-mail/WhatsApp) podem usar /uploads sem o /api.
  # Sem esta regra caem no `location /` e recebem o index.html do SPA com status 200 —
  # uma imagem quebrada que parece sucesso em qualquer log.
  location ^~ /uploads/ {
    alias /opt/apps/agendamentos-online-mvp/backend/uploads/;
    expires 30d;
    access_log off;
    add_header X-Content-Type-Options "nosniff" always;
    try_files $uri =404;
  }

  # Uploads servidos direto do disco, sem passar pelo Node.
  # ^~ garante precedencia sobre location regex e sobre /api/.
  # O Express continua montado em /api/uploads (backend/src/index.js) como
  # fallback caso este bloco seja removido.
  # Ajuste o alias para o caminho real do backend na maquina.
  location ^~ /api/uploads/ {
    alias /opt/apps/agendamentos-online-mvp/backend/uploads/;
    expires 30d;
    access_log off;
    add_header X-Content-Type-Options "nosniff" always;
    try_files $uri =404;
  }

  location /api/ {
    proxy_http_version 1.1;
    proxy_pass http://127.0.0.1:3002;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;

    # Nao sobrescreva X-Request-Id aqui. Mercado Pago e outros provedores podem
    # enviar esse header e a assinatura do webhook depende do valor original.
  }

  location / {
    try_files $uri $uri/ /index.html;
  }
}
