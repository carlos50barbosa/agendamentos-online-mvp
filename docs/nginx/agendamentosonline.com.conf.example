server {
  listen 80;
  server_name agenda0.com.br www.agenda0.com.br;

  root /var/www/agenda0.com.br;
  index index.html;

  location = /api {
    return 301 /api/;
  }

  location /api/ {
    proxy_http_version 1.1;
    proxy_pass http://127.0.0.1:3002;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;

    # Nao sobrescreva X-Request-Id aqui. Mercado Pago e outros provedores podem
    # enviar esse header e a assinatura do webhook depende do valor original.
  }

  location / {
    try_files $uri $uri/ /index.html;
  }
}
