# Renomeie para .env e preencha os valores
PORT=
MYSQL_HOST=localhost
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
JWT_SECRET=segredoo

# Notificacoes (opcionais)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
EMAIL_FROM="Agendamentos Online <noreply@example.com>"
SMTP_SECURE=false

# Destinos de alerta/boas-vindas
NEW_USER_ALERT_EMAIL=servicos.negocios.digital@gmail.com
BILLING_ALERT_EMAIL=servicos.negocios.digital@gmail.com

# WhatsApp Cloud API (fallback/dev)
WA_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WA_TOKEN=YOUR_META_CLOUD_API_TOKEN
WA_DEFAULT_TOKEN=
WA_API_VERSION=v23.0
WA_TEMPLATE_NAME=hello_world
WA_TEMPLATE_LANG=pt_BR
WA_FORCE_TEMPLATE=false
WHATSAPP_ALLOWED_LIST=
WHATSAPP_TO=+5500000000000

# WhatsApp Cloud API (embedded signup / multi-tenant)
WA_APP_ID=...
WA_APP_SECRET=...
WA_STATE_SECRET=
WA_STATE_TTL=1h
WA_VERIFY_TOKEN=...
WA_WEBHOOK_ALLOW_UNSIGNED=false
# NOTIFY_ROUTE_TOKEN e BILLING_WEBHOOK_HEALTH_TOKEN devem ser valores longos e aleatorios
# WA_WEBHOOK_ALLOW_UNSIGNED=true e MERCADOPAGO_ALLOW_UNSIGNED=true sao inseguros em producao
# Store do rate limit: memory (default local), mysql (compartilhado) ou redis (opcional com client injetado no bootstrap)
RATE_LIMIT_STORE=memory
RATE_LIMIT_FALLBACK_STORE=memory
# mysql exige a migracao backend/sql/2026-03-26-add-rate-limit-counters.sql
RATE_LIMIT_MYSQL_TABLE=rate_limit_counters
RATE_LIMIT_MYSQL_PRUNE_STRATEGY=interval
RATE_LIMIT_MYSQL_PRUNE_INTERVAL_MS=300000
RATE_LIMIT_MYSQL_PRUNE_BATCH_SIZE=500
RATE_LIMIT_MYSQL_PRUNE_MAX_BATCHES_PER_RUN=5
# Redis opcional: sem client compativel injetado no bootstrap, o store fara fallback
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_KEY_PREFIX=rate-limit:
# Rate limits operacionais das rotas sensiveis
NOTIFY_RATE_LIMIT_WINDOW_MS=60000
NOTIFY_RATE_LIMIT_MAX=20
PAYMENT_STATUS_RATE_LIMIT_WINDOW_MS=60000
PAYMENT_STATUS_RATE_LIMIT_MAX=60
# Telemetria leve de flood para webhooks/aliases
WEBHOOK_INVALID_SIGNATURE_ALERT_WINDOW_MS=60000
WEBHOOK_INVALID_SIGNATURE_ALERT_THRESHOLD=20
LEGACY_WEBHOOK_HIT_ALERT_WINDOW_MS=60000
LEGACY_WEBHOOK_HIT_ALERT_THRESHOLD=120
WA_TOKEN_ENC_KEY=y...
META_REDIRECT_URI=https://seu-dominio/api/wa/connect/callback
NOTIFY_ROUTE_TOKEN=
BILLING_WEBHOOK_HEALTH_TOKEN=
PUBLIC_DEPOSIT_TOKEN_DAYS=30
# Sunset planejado do fallback legado ?token= em /payments/:id/status
PAYMENTS_LEGACY_QUERY_TOKEN_ENABLED=true
PAYMENTS_LEGACY_QUERY_TOKEN_SUNSET_AT=
PAYMENTS_LEGACY_QUERY_TOKEN_DEPRECATION_URL=

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_ALLOW_UNSIGNED=false
# OAuth para conectar a conta do estabelecimento (Sinal/PIX)
MP_CLIENT_ID=
MP_CLIENT_SECRET=
# Ex.: https://seu-dominio.com/api/mercadopago/callback
MP_REDIRECT_URI=
# MP_STATE_SECRET: segredo para assinar o "state" do OAuth (fallback: JWT_SECRET)
MP_STATE_SECRET=
# MP_NOTIFICATION_URL deve ser o dominio publico do webhook em producao
MP_NOTIFICATION_URL=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_SUCCESS_URL=
MERCADOPAGO_FAILURE_URL=
MERCADOPAGO_PENDING_URL=
MERCADOPAGO_TEST_PAYER_EMAIL=
BILLING_CURRENCY=BRL
# Fidelidade no cartao: atraso da primeira cobranca recorrente e janela de protecao contra retries duplicados
CLIENT_LOYALTY_CARD_START_DELAY_MS=120000
CLIENT_LOYALTY_CARD_PENDING_WINDOW_MS=900000
SUBSCRIPTION_GRACE_DAYS=3
